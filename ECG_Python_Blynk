# ==========================================
# HỆ THỐNG LỌC VÀ GIAO DIỆN (Giữ nguyên như cũ)
# ==========================================
def remove_ecg_artifacts(data, threshold=500):
    data_clean = np.copy(data)
    mask = data_clean < threshold
    for idx in np.where(mask)[0]:
        mask[max(0, idx-5):min(len(data), idx+10)] = True
    good_idx, bad_idx = np.where(~mask)[0], np.where(mask)[0]
    if len(good_idx) > 0: data_clean[bad_idx] = np.interp(bad_idx, good_idx, data_clean[good_idx])
    return data_clean

def notch_filter(data, fs=1000.0):
    b, a = signal.iirnotch(50.0 / (0.5 * fs), 30.0)
    return signal.filtfilt(b, a, data)

def butter_bandpass(data, fs=1000.0):
    b, a = signal.butter(2, [0.5/(0.5 * fs), 40.0/(0.5 * fs)], btype='band')
    return signal.filtfilt(b, a, data)

def calculate_bpm(filtered_data):
    peaks, _ = signal.find_peaks(filtered_data, height=2400, distance=int(FS * 0.4))
    return int(60.0 / np.mean(np.diff(peaks) / FS)) if len(peaks) >= 2 else 0, peaks

