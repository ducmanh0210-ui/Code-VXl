# ==========================================
# 1. LUỒNG ĐỌC SERIAL (Bắt thêm chữ O)
# ==========================================
def read_serial_data():
    global raw_buffer, current_spo2
    try:
        ser = serial.Serial(PORT, BAUD, timeout=1)
        ser.reset_input_buffer() 
        print(f"\n[THANH CONG] Da ket noi. Dang lang nghe ECG va SpO2...")
        
        while True:
            try:
                line = ser.readline().decode('utf-8', errors='ignore').strip()
                if line:
                    parts = line.split(',')
                    
                    if parts[0] == 'E' and len(parts) == 2:
                        value = float(parts[1])
                        if value == 0: value = 2048.0
                        with lock:
                            raw_buffer = np.roll(raw_buffer, -1)
                            raw_buffer[-1] = value
                            
                    # BẮT GÓI DỮ LIỆU SPO2 (Chữ O)
                    elif parts[0] == 'O' and len(parts) == 2:
                        current_spo2 = int(parts[1])
                        
                    if ser.in_waiting > 2000:
                        ser.reset_input_buffer()
            except:
                pass
    except Exception as e:
        print(f"\n[LOI] Khong the ket noi {PORT}: {e}")

threading.Thread(target=read_serial_data, daemon=True).start()

